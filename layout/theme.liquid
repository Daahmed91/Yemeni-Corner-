<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_brown | default: '#4A2C2A' }}">

    {% render 'meta-tags' %}

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --color-gold: {{ settings.color_gold | default: '#C28839' }};
        --color-brown: {{ settings.color_brown | default: '#4A2C2A' }};
        --color-cream: {{ settings.color_cream | default: '#F5E6D3' }};
        --color-charcoal: {{ settings.color_charcoal | default: '#333333' }};
        --color-white: {{ settings.color_white | default: '#FFFDF8' }};
        --color-turquoise: {{ settings.color_turquoise | default: '#3AAFA9' }};
      }
    </style>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    {{ content_for_header }}
  </head>

  <body class="template-{{ template.name | handle }} {% if settings.enable_motion %}motion-enabled{% else %}motion-disabled{% endif %}">
    <a class="skip-link" href="#MainContent">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% render 'cart-drawer' %}

    {% sections 'footer-group' %}
  </body>
</html>
