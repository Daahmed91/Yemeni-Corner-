<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_brown | default: '#4A2C2A' }}">
    <meta name="google-site-verification" content="_SbzJZqIZD8zA2aC3k12tMYMwwiCo4QxIJ1KDU1tSzw">
    {% render 'favicon' %}

    {%- liquid
      assign seo_site_name = settings.seo_site_name | default: shop.name | strip
      assign shop_name_clean = shop.name | strip
      assign seo_title = page_title
      if template.name == 'index' and settings.seo_home_title != blank
        assign seo_title = settings.seo_home_title
      endif
      if template.name == 'product' and product != blank
        assign seo_product_title = product.title
        if seo_product_title contains 'Harraz' or seo_product_title contains 'Signature Roast'
          assign seo_title = 'Yemeni Corner: Signature Blend - Premium Whole Bean Coffee 340g'
        endif
      endif
      if shop_name_clean != blank and seo_site_name != shop_name_clean and seo_title contains shop.name
        assign seo_title = seo_title | replace: shop.name, seo_site_name
      endif
      if current_tags
        assign meta_tags = current_tags | join: ', '
        assign seo_title = seo_title | append: ' - ' | append: meta_tags
      endif
      if current_page != 1
        assign seo_title = seo_title | append: ' - Page ' | append: current_page
      endif
      unless seo_title contains seo_site_name
        assign seo_title = seo_title | append: ' - ' | append: seo_site_name
      endunless
      assign seo_title = seo_title | replace: 'Yemeni CornerSignature', 'Yemeni Corner Signature' | replace: 'Yemeni CornerHarraz', 'Yemeni Corner Harraz' | replace: 'Yemeni Corner|', 'Yemeni Corner |'

      assign seo_description = page_description | default: settings.brand_statement | default: shop.description
      if page_image
        assign social_image_url = page_image | image_url: width: 1200
      elsif settings.social_share_image != blank
        assign social_image_url = settings.social_share_image | image_url: width: 1200
      else
        assign social_image_url = 'yemeni-corner-social-share-1200x628.png' | asset_url
      endif
    -%}

    <title>{{ seo_title | escape }}</title>

    {% if seo_description %}
      <meta name="description" content="{{ seo_description | strip_html | escape }}">
    {% endif %}

    <link rel="canonical" href="{{ canonical_url }}">

    <meta property="og:site_name" content="{{ seo_site_name | escape }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ seo_title | escape }}">
    <meta property="og:type" content="website">

    {% if seo_description %}
      <meta property="og:description" content="{{ seo_description | strip_html | escape }}">
    {% endif %}

    {% if social_image_url != blank %}
      <meta property="og:image" content="https:{{ social_image_url }}">
      <meta property="og:image:secure_url" content="https:{{ social_image_url }}">
      {% unless page_image %}
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="628">
      {% endunless %}
      <meta property="og:image:alt" content="Yemeni Corner Signature Blend premium Yemeni coffee social preview">
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:image" content="https:{{ social_image_url }}">
    {% else %}
      <meta name="twitter:card" content="summary">
    {% endif %}

    <meta name="twitter:title" content="{{ seo_title | escape }}">
    {% if seo_description %}
      <meta name="twitter:description" content="{{ seo_description | strip_html | escape }}">
    {% endif %}

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": {{ seo_site_name | json }},
        "url": {{ shop.url | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": {{ shop.url | append: routes.search_url | append: '?q=%7Bsearch_term_string%7D' | json }},
          "query-input": "required name=search_term_string"
        }
      }
    </script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "CafeOrCoffeeShop",
        "@id": {{ shop.url | append: '#organization' | json }},
        "name": {{ seo_site_name | json }},
        "url": {{ shop.url | json }},
        "servesCuisine": ["Coffee", "Yemeni coffee", "Tea", "Dessert"],
        "department": [
          {
            "@type": "CafeOrCoffeeShop",
            "name": "Yemeni Corner South Windsor",
            "telephone": "519-915-0595",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "350 Cabana Rd E",
              "addressLocality": "Windsor",
              "addressRegion": "ON",
              "postalCode": "N9G 1A3",
              "addressCountry": "CA"
            }
          },
          {
            "@type": "CafeOrCoffeeShop",
            "name": "Yemeni Corner LaSalle",
            "telephone": "519-915-1119",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "5881 Malden Rd",
              "addressLocality": "LaSalle",
              "addressRegion": "ON",
              "addressCountry": "CA"
            }
          },
          {
            "@type": "CafeOrCoffeeShop",
            "name": "Yemeni Corner Mechanicsburg",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "4957 Carlisle Pike",
              "addressLocality": "Mechanicsburg",
              "addressRegion": "PA",
              "postalCode": "17050",
              "addressCountry": "US"
            }
          }
        ]
      }
    </script>

    {% if template.name == 'product' and product != blank %}
      {%- liquid
        assign structured_variant = product.selected_or_first_available_variant
        assign structured_description = product.description | strip_html | default: seo_description
        assign structured_product_name = product.title
        if structured_product_name contains 'Harraz' or structured_product_name contains 'Signature Roast'
          assign structured_product_name = 'Yemeni Corner Signature Blend'
        endif
      -%}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "Product",
          "name": {{ structured_product_name | json }},
          "description": {{ structured_description | strip | json }},
          "brand": {
            "@type": "Brand",
            "name": {{ seo_site_name | json }}
          },
          "image": [
            {% for media in product.media limit: 4 %}
              {{ media.preview_image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ],
          "offers": {
            "@type": "Offer",
            "url": {{ canonical_url | json }},
            "priceCurrency": {{ cart.currency.iso_code | json }},
            "price": {{ structured_variant.price | divided_by: 100.0 | json }},
            "availability": "https://schema.org/{% if structured_variant.available %}InStock{% else %}OutOfStock{% endif %}"
          }
        }
      </script>
    {% endif %}

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --color-gold: {{ settings.color_gold | default: '#C28839' }};
        --color-gold-text: #8F5D19;
        --color-brown: {{ settings.color_brown | default: '#4A2C2A' }};
        --color-cream: {{ settings.color_cream | default: '#F5E6D3' }};
        --color-charcoal: {{ settings.color_charcoal | default: '#333333' }};
        --color-white: {{ settings.color_white | default: '#FFFDF8' }};
        --color-turquoise: {{ settings.color_turquoise | default: '#3AAFA9' }};
      }
    </style>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    {{ content_for_header }}
  </head>

  <body class="template-{{ template.name | handle }} {% if settings.enable_motion %}motion-enabled{% else %}motion-disabled{% endif %}">
    <a class="skip-link" href="#MainContent">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% render 'cart-drawer' %}

    {% sections 'footer-group' %}
  </body>
</html>
