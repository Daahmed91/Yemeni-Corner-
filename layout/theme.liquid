<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_brown | default: '#4A2C2A' }}">

    {%- liquid
      assign seo_title = page_title
      if current_tags
        assign meta_tags = current_tags | join: ', '
        assign seo_title = seo_title | append: ' - ' | append: meta_tags
      endif
      if current_page != 1
        assign seo_title = seo_title | append: ' - Page ' | append: current_page
      endif
      unless seo_title contains shop.name
        assign seo_title = seo_title | append: ' - ' | append: shop.name
      endunless

      assign seo_description = page_description | default: settings.brand_statement | default: shop.description
    -%}

    <title>{{ seo_title | escape }}</title>

    {% if seo_description %}
      <meta name="description" content="{{ seo_description | strip_html | escape }}">
    {% endif %}

    <link rel="canonical" href="{{ canonical_url }}">

    <meta property="og:site_name" content="{{ shop.name | escape }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:type" content="website">

    {% if seo_description %}
      <meta property="og:description" content="{{ seo_description | strip_html | escape }}">
    {% endif %}

    {% if page_image %}
      <meta property="og:image" content="http:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta name="twitter:card" content="summary_large_image">
    {% else %}
      <meta name="twitter:card" content="summary">
    {% endif %}

    <meta name="twitter:title" content="{{ page_title | escape }}">
    {% if seo_description %}
      <meta name="twitter:description" content="{{ seo_description | strip_html | escape }}">
    {% endif %}

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": {{ shop.url | append: routes.search_url | append: '?q=%7Bsearch_term_string%7D' | json }},
          "query-input": "required name=search_term_string"
        }
      }
    </script>

    {% if template.name == 'product' and product != blank %}
      {%- liquid
        assign structured_variant = product.selected_or_first_available_variant
        assign structured_description = product.description | strip_html | default: seo_description
      -%}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "Product",
          "name": {{ product.title | json }},
          "description": {{ structured_description | strip | json }},
          "brand": {
            "@type": "Brand",
            "name": {{ shop.name | json }}
          },
          "image": [
            {% for media in product.media limit: 4 %}
              {{ media.preview_image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ],
          "offers": {
            "@type": "Offer",
            "url": {{ canonical_url | json }},
            "priceCurrency": {{ cart.currency.iso_code | json }},
            "price": {{ structured_variant.price | divided_by: 100.0 | json }},
            "availability": "https://schema.org/{% if structured_variant.available %}InStock{% else %}OutOfStock{% endif %}"
          }
        }
      </script>
    {% endif %}

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --color-gold: {{ settings.color_gold | default: '#C28839' }};
        --color-brown: {{ settings.color_brown | default: '#4A2C2A' }};
        --color-cream: {{ settings.color_cream | default: '#F5E6D3' }};
        --color-charcoal: {{ settings.color_charcoal | default: '#333333' }};
        --color-white: {{ settings.color_white | default: '#FFFDF8' }};
        --color-turquoise: {{ settings.color_turquoise | default: '#3AAFA9' }};
      }
    </style>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    {{ content_for_header }}
  </head>

  <body class="template-{{ template.name | handle }} {% if settings.enable_motion %}motion-enabled{% else %}motion-disabled{% endif %}">
    <a class="skip-link" href="#MainContent">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% render 'cart-drawer' %}

    {% sections 'footer-group' %}
  </body>
</html>
