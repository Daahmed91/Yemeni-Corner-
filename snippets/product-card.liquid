{% if product_card_product != blank %}
  <a class="product-card" href="{{ product_card_product.url }}">
    <div class="product-card__image">
      {% if product_card_product.featured_media %}
        {{
          product_card_product.featured_media.preview_image
          | image_url: width: 800
          | image_tag:
            widths: '360, 540, 720, 900',
            sizes: '(min-width: 960px) 33vw, 100vw',
            loading: 'lazy',
            alt: product_card_product.featured_media.alt | default: product_card_product.title
        }}
      {% else %}
        <img src="{{ 'yemeni-corner-bag.svg' | asset_url }}" alt="{{ product_card_product.title | escape }}" loading="lazy">
      {% endif %}
    </div>

    <div>
      <p class="eyebrow">{{ product_card_product.type | default: settings.brand_tagline }}</p>
      <h3>{{ product_card_product.title }}</h3>
      {% render 'price', product: product_card_product, show_from: true %}
    </div>
  </a>
{% endif %}
