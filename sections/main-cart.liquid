<section class="section" data-section-id="{{ section.id }}">
  <div class="page-width cart-page">
    <div class="section-header">
      <p class="eyebrow">Checkout</p>
      <h1 class="heading-lg">{{ 'cart.general.title' | t }}</h1>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="cart-items">
          {% for item in cart.items %}
            {%- liquid
              assign item_display_title = item.product.title
              if item_display_title contains 'Harraz' or item_display_title contains 'Signature Roast'
                assign item_display_title = 'Yemeni Corner Signature Blend'
              endif
            -%}
            <div class="cart-item">
              <div class="cart-item__image">
                {% if item.image %}
                  {{
                    item.image
                    | image_url: width: 220
                    | image_tag:
                      widths: '120, 180, 220',
                      sizes: '110px',
                      loading: 'lazy',
                      alt: item_display_title
                  }}
                {% else %}
                  <img src="{{ 'yemeni-corner-bag.svg' | asset_url }}" alt="{{ item_display_title | escape }}" width="900" height="1100" loading="lazy">
                {% endif %}
              </div>
              <div>
                <h2 class="heading-md"><a href="{{ item.url }}">{{ item_display_title }}</a></h2>
                {% unless item.product.has_only_default_variant %}
                  <p>{{ item.variant.title }}</p>
                {% endunless %}
                <p>{{ item.final_line_price | money }}</p>
              </div>
              <div class="cart-item__actions">
                {% render 'quantity-input', name: 'updates[]', value: item.quantity %}
                <p><a href="{{ item.url_to_remove }}">{{ 'cart.general.remove' | t }}</a></p>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="field">
          <label for="CartNote">{{ 'cart.general.note' | t }}</label>
          <textarea id="CartNote" class="textarea" name="note">{{ cart.note }}</textarea>
        </div>

        <div class="cart-summary">
          <p class="price">{{ 'cart.general.subtotal' | t }}: {{ cart.total_price | money }}</p>
          <p class="muted">Shipping and taxes are calculated at checkout.</p>
          <div class="button-row">
            <button class="button button--secondary" type="submit" name="update">{{ 'cart.general.update' | t }}</button>
            <button
              class="button"
              type="submit"
              name="checkout"
              data-yc-event="begin_checkout"
              data-yc-event-source="cart_page"
            >
              {{ 'cart.general.checkout' | t }}
            </button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="empty-state">
        <h2 class="heading-md">{{ 'cart.general.empty' | t }}</h2>
        <p>Your cart is ready for the Yemeni Corner Signature Blend, our flagship whole bean coffee for home brewing.</p>
        <a class="button" href="{{ routes.all_products_collection_url }}">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
