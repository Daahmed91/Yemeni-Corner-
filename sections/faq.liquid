<section class="section section--cream" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
    </div>

    <div class="faq-grid">
      {% for block in section.blocks %}
        <details class="faq-item" {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="faq-item__content">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Good to Know"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coffee questions, answered simply"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What size is the coffee bag?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Yemeni Corner Harraz Signature Roast is sold as a 340 g whole bean coffee bag.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "What size is the coffee bag?", "answer": "<p>Yemeni Corner Harraz Signature Roast is sold as a 340 g whole bean coffee bag.</p>" } },
        { "type": "question", "settings": { "question": "What does it taste like?", "answer": "<p>The roast is built around warm spice, cocoa, and dried fruit notes with a smooth, aromatic finish.</p>" } },
        { "type": "question", "settings": { "question": "How should I brew it?", "answer": "<p>It works beautifully with drip, French press, pour-over, and espresso. Grind fresh for the best cup.</p>" } },
        { "type": "question", "settings": { "question": "Can I order cafe drinks online?", "answer": "<p>The cafe menu is served in person at Yemeni Corner. The online shop is focused on whole bean coffee for home brewing.</p>" } },
        { "type": "question", "settings": { "question": "Where do you ship?", "answer": "<p>The online shop is set up for Canadian customers. Shipping rates and delivery options are shown at checkout.</p>" } }
      ]
    }
  ]
}
{% endschema %}
