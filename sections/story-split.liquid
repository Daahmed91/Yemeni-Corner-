{%- liquid
  assign story_page = pages['story']
  assign story_url = story_page.url | default: '/pages/story'
  assign button_url = section.settings.button_link | default: story_url
-%}

<section class="section section--{{ section.settings.background }}" data-section-id="{{ section.id }}">
  <div class="page-width split {% if section.settings.image_position == 'right' %}split--reverse{% endif %}">
    <div class="split__media">
      <div class="media-panel media-panel--placeholder">
        {% if section.settings.image != blank %}
          {% render 'responsive-image',
            image: section.settings.image,
            width: 1200,
            sizes: '(min-width: 960px) 48vw, 92vw',
            alt: section.settings.heading
          %}
        {% else %}
          <img src="{{ 'yemeni-corner-ritual.webp' | asset_url }}" alt="{{ section.settings.heading | escape }}" width="1448" height="1086" loading="lazy">
        {% endif %}
        {% if section.settings.badge != blank %}
          <div class="media-panel__badge">{{ section.settings.badge }}</div>
        {% endif %}
      </div>
    </div>

    <div class="split__content">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <div class="lead rte">{{ section.settings.text }}</div>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <div class="button-row">
          <a class="button button--secondary" href="{{ button_url }}">{{ section.settings.button_label }}</a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story split",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "default": "white",
      "options": [
        { "value": "white", "label": "Warm white" },
        { "value": "cream", "label": "Cream" },
        { "value": "brown", "label": "Brown" }
      ]
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Coffee From Its Birthplace"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rooted in Yemen's coffee heritage"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Yemen has one of the richest coffee histories in the world. Yemeni Corner brings that heritage into a modern, premium roast made for today's home coffee ritual.</p>"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Image badge",
      "default": "Heritage-led. Warm. Modern."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read the Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Story split"
    }
  ]
}
{% endschema %}
