{%- liquid
  assign featured_product = all_products[section.settings.product]
  assign product_url = routes.all_products_collection_url
  if featured_product != blank
    assign product_url = featured_product.url
  endif
  assign story_page = pages['story']
  assign story_url = routes.root_url | append: '#story'
  if story_page != blank
    assign story_url = story_page.url
  endif
-%}

<section class="section" data-section-id="{{ section.id }}">
  <div class="page-width featured-product">
    <div class="featured-product__image" data-reveal data-parallax data-parallax-speed="0.025">
      <span class="featured-product__badge">340 g whole bean</span>
      {% if featured_product.featured_media %}
        {{
          featured_product.featured_media.preview_image
          | image_url: width: 1200
          | image_tag:
            widths: '480, 720, 960, 1200',
            sizes: '(min-width: 960px) 42vw, 92vw',
            loading: 'lazy',
            alt: featured_product.featured_media.alt | default: featured_product.title
        }}
      {% else %}
        <img src="{{ 'yemeni-corner-bag.svg' | asset_url }}" alt="Yemeni Corner Harraz Signature Roast coffee bag" width="900" height="1100" loading="lazy">
      {% endif %}
    </div>

    <div class="featured-product__content" data-reveal>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">
        {% if featured_product != blank %}
          {{ featured_product.title }}
        {% else %}
          {{ section.settings.heading }}
        {% endif %}
      </h2>
      <p class="lead">{{ section.settings.text }}</p>

      {% if featured_product != blank %}
        <div class="featured-product__price">
          {% render 'price', product: featured_product %}
          <span class="featured-product__status">
            {% if featured_product.available %}
              Ready to add to cart
            {% else %}
              Temporarily unavailable
            {% endif %}
          </span>
        </div>
      {% endif %}

      <div class="product-points">
        <div class="point" data-reveal>
          <span>Tasting Notes</span>
          <strong>Warm spice, cocoa, dried fruit</strong>
        </div>
        <div class="point" data-reveal>
          <span>Roast Level</span>
          <strong>Medium, smooth, aromatic</strong>
        </div>
        <div class="point" data-reveal>
          <span>Best For</span>
          <strong>Drip, French press, pour-over, espresso</strong>
        </div>
      </div>

      <div class="button-row">
        <a class="button" href="{{ product_url }}">{{ section.settings.button_label }}</a>
        <a class="button button--secondary" href="{{ story_url }}">Why Yemeni Coffee</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Signature product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Signature Roast"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Yemeni Corner Harraz Signature Roast"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A 340 g whole bean coffee with a medium roast profile and notes of warm spice, cocoa, and dried fruit. One focused roast connects the cafe story to everyday brewing at home."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Harraz Roast"
    }
  ],
  "presets": [
    {
      "name": "Signature product"
    }
  ]
}
{% endschema %}
