<section class="section" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="heading-lg">{{ collection.title | default: section.settings.heading }}</h1>
      {% if collection.description != blank %}
        <div class="lead rte">{{ collection.description }}</div>
      {% else %}
        <p class="lead">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    {% paginate collection.products by 12 %}
      {% if collection.products.size > 0 %}
        <div class="collection-grid">
          {% for product in collection.products %}
            {% render 'product-card', product_card_product: product %}
          {% endfor %}
        </div>
        {% render 'pagination', paginate: paginate %}
      {% else %}
        <div class="empty-state">
          <h2 class="heading-md">The first roast is almost ready.</h2>
          <p>Set up Yemeni Corner Signature Roast in Shopify admin and assign it to this collection.</p>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop Coffee"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Premium Yemeni coffee, simply chosen"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Fallback text",
      "default": "Launch begins with one flagship 340 g whole bean coffee: Yemeni Corner Signature Roast."
    }
  ]
}
{% endschema %}
