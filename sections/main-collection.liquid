<section class="section" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="heading-lg">{{ collection.title | default: section.settings.heading }}</h1>
      {% if collection.description != blank %}
        <div class="lead rte">{{ collection.description }}</div>
      {% else %}
        <p class="lead">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    {% paginate collection.products by 12 %}
      {% if collection.products.size > 0 %}
        <div class="collection-grid">
          {% for product in collection.products %}
            {% render 'product-card', product_card_product: product %}
          {% endfor %}
        </div>
        {% render 'pagination', paginate: paginate %}
      {% else %}
        <div class="empty-state">
          <h2 class="heading-md">Coffee is coming back soon.</h2>
          <p>Our Yemeni Corner Signature Blend is the flagship online coffee. Check back shortly or visit the cafe menu while we restock the shop.</p>
          <a class="button" href="/pages/menu">View Cafe Menu</a>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop Coffee"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "One blend, chosen with purpose"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Fallback text",
      "default": "Shop Yemeni Corner's flagship 340 g whole bean coffee: a medium roast Yemeni Corner Signature Blend with warm spice, cocoa, and dried fruit notes."
    }
  ]
}
{% endschema %}
