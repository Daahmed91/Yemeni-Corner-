{%- liquid
  assign featured_product = all_products[section.settings.product]
  assign hero_image = section.settings.image
  if hero_image == blank and featured_product.featured_media
    assign hero_image = featured_product.featured_media.preview_image
  endif
  assign primary_url = section.settings.primary_link | default: routes.all_products_collection_url
  assign secondary_url = section.settings.secondary_link | default: '/pages/story'
-%}

<section class="hero-coffee" data-section-id="{{ section.id }}">
  <div class="page-width hero-coffee__inner">
    <div class="hero-coffee__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="heading-xl">{{ section.settings.heading }}</h1>
      {% if section.settings.text != blank %}
        <div class="lead">{{ section.settings.text }}</div>
      {% endif %}

      <div class="button-row">
        <a class="button button--gold" href="{{ primary_url }}">{{ section.settings.primary_label }}</a>
        <a class="button button--secondary" href="{{ secondary_url }}">{{ section.settings.secondary_label }}</a>
      </div>

      <div class="trust-strip" aria-label="Coffee highlights">
        <div class="trust-item">
          <strong>340 g</strong>
          <span>Whole bean coffee</span>
        </div>
        <div class="trust-item">
          <strong>Medium</strong>
          <span>Balanced roast profile</span>
        </div>
        <div class="trust-item">
          <strong>Canada</strong>
          <span>Launching online first</span>
        </div>
      </div>
    </div>

    <div class="hero-coffee__media">
      <div class="hero-coffee__media-frame">
        {% render 'responsive-image',
          image: hero_image,
          width: 1200,
          sizes: '(min-width: 960px) 48vw, 92vw',
          loading: 'eager',
          alt: section.settings.image_alt
        %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Coffee hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Yemeni Coffee"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Yemen in Every Sip"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A rich, smooth roast inspired by Yemen's deep coffee heritage. Crafted for slow mornings, family gatherings, and everyday rituals."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Coffee"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Featured product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Yemeni Corner Signature Roast coffee bag"
    }
  ],
  "presets": [
    {
      "name": "Coffee hero"
    }
  ]
}
{% endschema %}
