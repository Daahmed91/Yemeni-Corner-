{%- liquid
  assign featured_product = all_products[section.settings.product]
  assign story_page = pages['story']
  assign story_url = routes.root_url | append: '#story'
  if story_page != blank
    assign story_url = story_page.url
  endif
  assign hero_image = section.settings.image
  if hero_image == blank and featured_product.featured_media
    assign hero_image = featured_product.featured_media.preview_image
  endif
  assign primary_url = section.settings.primary_link
  if primary_url == blank and featured_product != blank
    assign primary_url = featured_product.url
  endif
  if primary_url == blank
    assign primary_url = routes.all_products_collection_url
  endif
  assign secondary_url = section.settings.secondary_link | default: story_url
-%}

<section class="hero-coffee" data-section-id="{{ section.id }}" aria-labelledby="HeroHeading-{{ section.id }}">
  <div class="hero-coffee__brand-mark" data-parallax data-parallax-speed="-0.08" aria-hidden="true">
    {% if settings.logo_mark != blank %}
      {{
        settings.logo_mark
        | image_url: width: 520
        | image_tag:
          widths: '220, 360, 520',
          sizes: '220px',
          loading: 'eager',
          alt: ''
      }}
    {% else %}
      <img src="{{ 'yemeni-corner-mark.png' | asset_url }}" alt="" width="400" height="497" loading="eager">
    {% endif %}
  </div>
  <div class="page-width hero-coffee__inner">
    <div class="hero-coffee__copy" data-reveal>
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 id="HeroHeading-{{ section.id }}" class="heading-xl">{{ section.settings.heading }}</h1>
      {% if section.settings.text != blank %}
        <div class="lead">{{ section.settings.text }}</div>
      {% endif %}

      <div class="hero-coffee__aromas" aria-label="Signature roast tasting notes">
        <span>Warm spice</span>
        <span>Cocoa</span>
        <span>Dried fruit</span>
      </div>

      <div class="button-row">
        <a class="button button--gold" href="{{ primary_url }}">{{ section.settings.primary_label }}</a>
        <a class="button button--secondary" href="{{ secondary_url }}">{{ section.settings.secondary_label }}</a>
      </div>

      <div class="trust-strip" aria-label="Coffee highlights">
        <div class="trust-item" data-reveal>
          <strong>340 g</strong>
          <span>Whole bean coffee</span>
        </div>
        <div class="trust-item" data-reveal>
          <strong>Medium</strong>
          <span>Balanced roast profile</span>
        </div>
        <div class="trust-item" data-reveal>
          <strong>Canada</strong>
          <span>Ships from our Canadian store</span>
        </div>
      </div>
    </div>

    <div class="hero-coffee__media" data-reveal data-parallax data-parallax-speed="0.05">
      <div class="hero-coffee__media-frame" data-parallax data-parallax-speed="0.03">
        {% render 'responsive-image',
          image: hero_image,
          width: 1200,
          sizes: '(min-width: 960px) 48vw, 92vw',
          loading: 'eager',
          alt: section.settings.image_alt,
          image_class: 'hero-coffee__product'
        %}
        <div class="hero-coffee__note" aria-label="Launch roast details">
          <span>Launch roast</span>
          <strong>Harraz Signature Roast</strong>
          <span>Whole bean coffee for home brewing</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Coffee hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Yemeni Coffee, Shared Warmly"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Yemeni Corner Coffee"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A coffee house story rooted in Yemeni hospitality, traditional drinks, and the Harraz Signature Roast you can brew at home."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Harraz Roast"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Featured product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Yemeni Corner Harraz Signature Roast coffee bag"
    }
  ],
  "presets": [
    {
      "name": "Coffee hero"
    }
  ]
}
{% endschema %}
