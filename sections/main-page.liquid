<section class="section" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="heading-lg">{{ page.title }}</h1>
    </div>

    <div class="rte">
      {% if page.content != blank %}
        {{ page.content }}
      {% else %}
        <p>{{ section.settings.fallback_text }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Yemeni Corner"
    },
    {
      "type": "textarea",
      "id": "fallback_text",
      "label": "Fallback text",
      "default": "Explore Yemeni Corner coffee, the cafe menu, and the story behind our Harraz Signature Roast."
    }
  ]
}
{% endschema %}
