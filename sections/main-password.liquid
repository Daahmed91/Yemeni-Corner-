<section class="section" data-section-id="{{ section.id }}">
  <div class="page-width newsletter">
    <div class="newsletter__inner">
      <div>
        <p class="eyebrow">{{ settings.brand_tagline }}</p>
        <h1 class="heading-md">{{ section.settings.heading }}</h1>
        <p class="lead">{{ section.settings.text }}</p>
      </div>

      {% form 'storefront_password' %}
        <div class="field">
          <label for="Password">{{ section.settings.password_label }}</label>
          <input id="Password" class="input" type="password" name="password" autocomplete="current-password">
        </div>
        <button class="button button--gold" type="submit">{{ section.settings.button_label }}</button>
        {% if form.errors %}
          <div class="form-message">{{ form.errors | default_errors }}</div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main password",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The first blend is coming soon"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Premium Yemeni coffee, cafe hospitality, and the Yemeni Corner Signature Blend are being prepared for your visit. Enter the store password to preview the theme."
    },
    {
      "type": "text",
      "id": "password_label",
      "label": "Password label",
      "default": "Store password"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Enter"
    }
  ]
}
{% endschema %}
