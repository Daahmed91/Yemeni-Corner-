<section class="section section--cream" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      <p class="lead">{{ section.settings.text }}</p>
    </div>

    <div class="location-grid">
      {% for block in section.blocks %}
        <article class="location-card" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title }}</h3>
          <address>{{ block.settings.address | newline_to_br }}</address>
          <p>{{ block.settings.hours | newline_to_br }}</p>
          {% if block.settings.phone != blank %}
            <p><a href="tel:{{ block.settings.phone | remove: ' ' | remove: '-' }}">{{ block.settings.phone }}</a></p>
          {% endif %}
          {% if block.settings.map_link != blank %}
            <a class="button button--secondary" href="{{ block.settings.map_link }}">Get Directions</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Locations preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Visit Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coffee houses in Windsor and LaSalle"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Come for a cup, stay for the warmth. Our cafes bring Yemeni coffee, desserts, and hospitality into welcoming local spaces."
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "South Windsor"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "350 Cabana Rd E\nWindsor, ON N9G 1A3"
        },
        {
          "type": "textarea",
          "id": "hours",
          "label": "Hours",
          "default": "Mon-Thu: 9am-12am\nFri-Sat: 9am-2am\nSun: 9am-12am"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone",
          "default": "519-915-0595"
        },
        {
          "type": "url",
          "id": "map_link",
          "label": "Map link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Locations preview",
      "blocks": [
        { "type": "location", "settings": { "title": "South Windsor", "address": "350 Cabana Rd E\nWindsor, ON N9G 1A3", "hours": "Mon-Thu: 9am-12am\nFri-Sat: 9am-2am\nSun: 9am-12am", "phone": "519-915-0595" } },
        { "type": "location", "settings": { "title": "LaSalle", "address": "5881 Malden Rd\nLaSalle, ON", "hours": "Open daily for coffee, desserts, and warm hospitality.", "phone": "519-915-1119" } }
      ]
    }
  ]
}
{% endschema %}
