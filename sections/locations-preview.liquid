{%- liquid
  assign section_anchor = section.settings.anchor_id | handle
-%}

<section
  class="section section--cream"
  {% if section_anchor != blank %}id="{{ section_anchor }}"{% endif %}
  data-section-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="section-header" data-reveal>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      <p class="lead">{{ section.settings.text }}</p>
    </div>

    <div class="location-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign phone_href = block.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.'
          assign location_page_handle = block.settings.title | handle
          assign location_page = pages[location_page_handle]
          assign location_page_url = ''
          if location_page != blank
            assign location_page_url = location_page.url
          elsif block.settings.page_link contains '#'
            assign location_page_url = block.settings.page_link
          endif
        -%}
        <article class="location-card" data-reveal {{ block.shopify_attributes }}>
          <span class="location-card__label">Yemeni Corner Cafe</span>
          <h3>{{ block.settings.title }}</h3>
          <address>{{ block.settings.address | newline_to_br }}</address>
          <p>{{ block.settings.hours | newline_to_br }}</p>
          <div class="location-card__actions">
            {% if block.settings.phone != blank %}
              <a
                class="button button--secondary"
                href="tel:{{ phone_href }}"
                data-yc-event="phone_click"
                data-yc-event-location="{{ block.settings.title | escape }}"
                data-yc-event-source="locations_card"
              >
                {{ block.settings.phone }}
              </a>
            {% endif %}
            {% if block.settings.map_link != blank %}
              <a
                class="button"
                href="{{ block.settings.map_link }}"
                data-yc-event="directions_click"
                data-yc-event-location="{{ block.settings.title | escape }}"
                data-yc-event-source="locations_card"
              >
                Get Directions
              </a>
            {% endif %}
            {% if location_page_url != blank %}
              <a class="button button--secondary" href="{{ location_page_url }}">View Location</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Locations preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Visit Us"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Optional anchor ID"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coffee houses in Ontario and Pennsylvania"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Visit Yemeni Corner for traditional drinks, signature lattes, cold favorites, desserts, and warm hospitality in South Windsor, LaSalle, or Mechanicsburg. Order the Yemeni Corner Signature Blend online when you want the ritual at home."
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "South Windsor"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "350 Cabana Rd E\nWindsor, ON N9G 1A3"
        },
        {
          "type": "textarea",
          "id": "hours",
          "label": "Hours",
          "default": "Mon-Thu: 9am-12am\nFri-Sat: 9am-2am\nSun: 9am-12am"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone",
          "default": "519-915-0595"
        },
        {
          "type": "url",
          "id": "map_link",
          "label": "Map link"
        },
        {
          "type": "url",
          "id": "page_link",
          "label": "Location page link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Locations preview",
      "blocks": [
        { "type": "location", "settings": { "title": "South Windsor", "address": "350 Cabana Rd E\nWindsor, ON N9G 1A3", "hours": "Mon-Thu: 9am-12am\nFri-Sat: 9am-2am\nSun: 9am-12am", "phone": "519-915-0595", "page_link": "/pages/south-windsor" } },
        { "type": "location", "settings": { "title": "LaSalle", "address": "5881 Malden Rd\nLaSalle, ON", "hours": "Open daily for coffee, desserts, and warm hospitality. Confirm holiday hours by phone.", "phone": "519-915-1119", "page_link": "/pages/lasalle" } },
        { "type": "location", "settings": { "title": "Mechanicsburg, PA", "address": "4957 Carlisle Pike\nMechanicsburg, PA 17050", "hours": "Open daily for coffee, desserts, and warm hospitality. Confirm current hours before visiting.", "phone": "", "map_link": "https://share.google/wcsuVJwqdAe4cnCKP", "page_link": "" } }
      ]
    }
  ]
}
{% endschema %}
