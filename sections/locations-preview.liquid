{%- liquid
  assign section_anchor = section.settings.anchor_id | handle
-%}

<section
  class="section section--cream"
  {% if section_anchor != blank %}id="{{ section_anchor }}"{% endif %}
  data-section-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="section-header" data-reveal>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      <p class="lead">{{ section.settings.text }}</p>
    </div>

    <div class="location-grid">
      {% for block in section.blocks %}
        <article class="location-card" data-reveal {{ block.shopify_attributes }}>
          <span class="location-card__label">Yemeni Corner Cafe</span>
          <h3>{{ block.settings.title }}</h3>
          <address>{{ block.settings.address | newline_to_br }}</address>
          <p>{{ block.settings.hours | newline_to_br }}</p>
          <div class="location-card__actions">
            {% if block.settings.phone != blank %}
              <a class="button button--secondary" href="tel:{{ block.settings.phone | remove: ' ' | remove: '-' }}">{{ block.settings.phone }}</a>
            {% endif %}
            {% if block.settings.map_link != blank %}
              <a class="button" href="{{ block.settings.map_link }}">Get Directions</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Locations preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Visit Us"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Optional anchor ID"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coffee houses in Windsor and LaSalle"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Visit Yemeni Corner for traditional drinks, signature lattes, cold favorites, desserts, and warm hospitality. Order the Harraz Signature Roast online when you want the ritual at home."
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "South Windsor"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "350 Cabana Rd E\nWindsor, ON N9G 1A3"
        },
        {
          "type": "textarea",
          "id": "hours",
          "label": "Hours",
          "default": "Mon-Thu: 9am-12am\nFri-Sat: 9am-2am\nSun: 9am-12am"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone",
          "default": "519-915-0595"
        },
        {
          "type": "url",
          "id": "map_link",
          "label": "Map link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Locations preview",
      "blocks": [
        { "type": "location", "settings": { "title": "South Windsor", "address": "350 Cabana Rd E\nWindsor, ON N9G 1A3", "hours": "Mon-Thu: 9am-12am\nFri-Sat: 9am-2am\nSun: 9am-12am", "phone": "519-915-0595" } },
        { "type": "location", "settings": { "title": "LaSalle", "address": "5881 Malden Rd\nLaSalle, ON", "hours": "Open daily for coffee, desserts, and warm hospitality. Confirm holiday hours by phone.", "phone": "519-915-1119" } }
      ]
    }
  ]
}
{% endschema %}
