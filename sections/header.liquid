{%- liquid
  assign navigation = linklists[section.settings.menu]
  assign story_page = pages['story']
  assign menu_page = pages['menu']
  assign locations_page = pages['locations']
  assign contact_page = pages['contact']
  assign brand_name = settings.seo_site_name | default: shop.name
  assign story_url = routes.root_url | append: '#story'
  if story_page != blank
    assign story_url = story_page.url
  endif
  assign menu_url = menu_page.url | default: '/pages/menu'
  assign locations_url = routes.root_url | append: '#locations'
  if locations_page != blank
    assign locations_url = locations_page.url
  endif
  assign careers_url = '/careers'
  assign contact_url = contact_page.url | default: '/pages/contact'
  assign coffee_collection = collections['coffee']
  assign shop_url = section.settings.shop_link
  if shop_url == blank and coffee_collection != blank
    assign shop_url = coffee_collection.url
  endif
  if shop_url == blank
    assign shop_url = routes.all_products_collection_url
  endif
  assign shop_button_url = section.settings.shop_button_link | default: shop_url
-%}

<header class="site-header" data-section-id="{{ section.id }}">
  <div class="page-width site-header__inner">
    <a class="site-header__brand" href="{{ routes.root_url }}" aria-label="{{ brand_name }}">
      {% if settings.logo != blank %}
        {{
          settings.logo
          | image_url: width: 320
          | image_tag:
            widths: '160, 240, 320',
            sizes: '160px',
            loading: 'eager',
            class: 'site-header__logo',
            alt: brand_name
        }}
      {% else %}
        <img
          class="site-header__fallback-logo"
          src="{{ 'yemeni-corner-logo-header.png' | asset_url }}"
          width="715"
          height="140"
          loading="eager"
          alt="{{ brand_name | escape }}"
        >
      {% endif %}
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <ul class="site-nav__list">
        {% if section.settings.use_curated_navigation %}
          <li><a class="site-nav__link" href="{{ routes.root_url }}">Home</a></li>
          <li><a class="site-nav__link" href="{{ shop_url }}">Shop Coffee</a></li>
          <li><a class="site-nav__link" href="{{ story_url }}">Story</a></li>
          <li><a class="site-nav__link" href="{{ menu_url }}">Cafe Menu</a></li>
          <li><a class="site-nav__link" href="{{ locations_url }}">Locations</a></li>
          <li><a class="site-nav__link" href="{{ careers_url }}">Careers</a></li>
          <li><a class="site-nav__link" href="{{ contact_url }}">Contact</a></li>
        {% elsif navigation.links.size > 0 %}
          {% for link in navigation.links %}
            {%- liquid
              assign link_url = link.url
              assign link_title_handle = link.title | handle
              if link_title_handle == 'careers'
                assign link_url = careers_url
              endif
            -%}
            <li>
              <a class="site-nav__link" href="{{ link_url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        {% else %}
          <li><a class="site-nav__link" href="{{ routes.root_url }}">Home</a></li>
          <li><a class="site-nav__link" href="{{ shop_url }}">Shop Coffee</a></li>
          <li><a class="site-nav__link" href="{{ story_url }}">Story</a></li>
          <li><a class="site-nav__link" href="{{ menu_url }}">Cafe Menu</a></li>
          <li><a class="site-nav__link" href="{{ locations_url }}">Locations</a></li>
          <li><a class="site-nav__link" href="{{ careers_url }}">Careers</a></li>
          <li><a class="site-nav__link" href="{{ contact_url }}">Contact</a></li>
        {% endif %}
      </ul>
    </nav>

    <div class="site-header__actions">
      {% if section.settings.show_shop_button %}
        <a class="button button--gold site-header__shop-button" href="{{ shop_button_url }}">
          {{ section.settings.shop_button_label }}
        </a>
      {% endif %}
      <a class="header-action header-action--search" href="{{ routes.search_url }}" aria-label="{{ 'general.search.search' | t }}">Search</a>
      <a class="header-action header-action--cart" href="{{ routes.cart_url }}" aria-label="{{ 'cart.general.title' | t }}">
        Cart
        <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
      <button
        class="header-action menu-toggle"
        type="button"
        data-drawer-open="#MobileMenu"
        aria-controls="MobileMenu"
        aria-expanded="false"
        aria-label="{{ 'general.accessibility.menu' | t }}"
      >
        Menu
      </button>
    </div>
  </div>

</header>

<div id="MobileMenu" class="mobile-drawer" aria-hidden="true">
  <button class="mobile-drawer__backdrop" type="button" data-drawer-close aria-label="{{ 'general.accessibility.close' | t }}"></button>
  <div class="mobile-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ 'general.accessibility.menu' | t }}" tabindex="-1">
    <button class="header-action" type="button" data-drawer-close>{{ 'general.accessibility.close' | t }}</button>
    <nav class="mobile-drawer__nav" aria-label="Mobile navigation">
      {% if section.settings.use_curated_navigation %}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ shop_url }}">Shop Coffee</a>
        <a href="{{ story_url }}">Story</a>
        <a href="{{ menu_url }}">Cafe Menu</a>
        <a href="{{ locations_url }}">Locations</a>
        <a href="{{ careers_url }}">Careers</a>
        <a href="{{ contact_url }}">Contact</a>
        <a href="{{ routes.cart_url }}">Cart</a>
      {% elsif navigation.links.size > 0 %}
        {% for link in navigation.links %}
          {%- liquid
            assign link_url = link.url
            assign link_title_handle = link.title | handle
            if link_title_handle == 'careers'
              assign link_url = careers_url
            endif
          -%}
          <a href="{{ link_url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ shop_url }}">Shop Coffee</a>
        <a href="{{ story_url }}">Story</a>
        <a href="{{ menu_url }}">Cafe Menu</a>
        <a href="{{ locations_url }}">Locations</a>
        <a href="{{ careers_url }}">Careers</a>
        <a href="{{ contact_url }}">Contact</a>
        <a href="{{ routes.cart_url }}">Cart</a>
      {% endif %}
    </nav>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "use_curated_navigation",
      "label": "Use curated coffee navigation",
      "default": true
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Shop Coffee navigation link"
    },
    {
      "type": "checkbox",
      "id": "show_shop_button",
      "label": "Show shop button",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_button_label",
      "label": "Shop button label",
      "default": "Shop Coffee"
    },
    {
      "type": "url",
      "id": "shop_button_link",
      "label": "Shop button link"
    }
  ]
}
{% endschema %}
