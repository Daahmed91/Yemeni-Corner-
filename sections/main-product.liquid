{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign bag_size = product.metafields.custom.bag_size.value | default: section.settings.bag_size
  assign tasting_notes = product.metafields.custom.tasting_notes.value | default: section.settings.tasting_notes
  assign roast_level = product.metafields.custom.roast_level.value | default: section.settings.roast_level
  assign roast_date = product.metafields.custom.roast_date.value | default: section.settings.roast_date
  assign coffee_process = product.metafields.custom.coffee_process.value | default: section.settings.coffee_process
  assign origin_importer = product.metafields.custom.origin_importer.value | default: section.settings.origin_importer
  assign grind_format = product.metafields.custom.grind_format.value | default: section.settings.grind_format
  assign shipping_returns = product.metafields.custom.shipping_returns.value | default: section.settings.shipping_returns
  assign brew_methods = product.metafields.custom.brew_methods.value | default: section.settings.best_for
  assign origin_context = product.metafields.custom.origin_context.value | default: section.settings.origin_context
  assign gift_message = product.metafields.custom.gift_message.value | default: section.settings.gift_message
  assign trust_copy = product.metafields.custom.trust_copy.value | default: section.settings.trust_copy
  assign product_display_title = product.title
  if product_display_title contains 'Harraz' or product_display_title contains 'Signature Roast'
    assign product_display_title = 'Yemeni Corner Signature Blend'
  endif
  assign use_fallback_description = false
  if product.description contains 'Signature Roast' or product.description contains 'Sourced from' or product.description contains 'Harraz mountains'
    assign use_fallback_description = true
  endif
-%}

<section
  class="section"
  data-section-id="{{ section.id }}"
  data-yc-view-item
  data-yc-product-render="signature-blend-title-2026-06-06"
  data-yc-event-item-id="{{ product.id }}"
  data-yc-event-item-name="{{ product_display_title | escape }}"
  data-yc-event-variant-id="{{ current_variant.id }}"
  data-yc-event-price="{{ current_variant.price | divided_by: 100.0 }}"
  data-yc-event-currency="{{ cart.currency.iso_code }}"
>
  <div class="page-width product">
    <div class="product__media">
      <div class="product__media-main">
        {% if product.featured_media %}
          {{
            product.featured_media.preview_image
            | image_url: width: 1400
            | image_tag:
              widths: '520, 720, 960, 1200, 1400',
              sizes: '(min-width: 960px) 52vw, 92vw',
              loading: 'eager',
              alt: product_display_title
          }}
        {% else %}
          <img src="{{ 'yc-signature-blend-product.webp' | asset_url }}" alt="{{ product_display_title | escape }}" width="1100" height="1300" loading="eager">
        {% endif %}
      </div>

      {% if product.media.size > 1 %}
        <div class="collection-grid">
          {% for media in product.media offset: 1 limit: 3 %}
            <div class="product-card__image">
              {{
                media.preview_image
                | image_url: width: 600
                | image_tag:
                  widths: '240, 360, 480, 600',
                  sizes: '(min-width: 960px) 16vw, 30vw',
                  loading: 'lazy',
                  alt: product_display_title
              }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product__info">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="heading-md">{{ product_display_title }}</h1>
      <p class="lead">{{ section.settings.subtitle }}</p>

      <div>
        {% render 'price', product: product %}
      </div>

      <div class="product__trust" aria-label="Product highlights">
        <span>{{ grind_format }}</span>
        <span>{{ roast_date }}</span>
        <span>{{ section.settings.market }}</span>
      </div>

      {% form 'product', product, class: 'product-form' %}
        {% if product.has_only_default_variant %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% else %}
          <div class="field">
            <label for="VariantSelect-{{ section.id }}">Choose option</label>
            <select id="VariantSelect-{{ section.id }}" class="select" name="id">
              {% for variant in product.variants %}
                <option
                  value="{{ variant.id }}"
                  {% if variant == current_variant %}selected="selected"{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {{ variant.title }} - {{ variant.price | money }}
                </option>
              {% endfor %}
            </select>
          </div>
        {% endif %}

        <div class="field">
          <label>{{ 'products.product.quantity' | t }}</label>
          {% render 'quantity-input' %}
        </div>

        <button
          class="button"
          type="submit"
          name="add"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {% if current_variant.available %}
            {{ 'products.product.add_to_cart' | t }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>

        <p class="form-message" data-product-status aria-live="polite"></p>

        {% if section.settings.show_dynamic_checkout %}
          {{ form | payment_button }}
        {% endif %}
      {% endform %}

      {% if trust_copy != blank %}
        <p class="product__confidence">{{ trust_copy }}</p>
      {% endif %}

      <div class="product-nudges" aria-label="Ways to enjoy this coffee">
        <span>One to brew, one to gift</span>
        <span>Stock up for the week</span>
        <span>Share the cafe ritual at home</span>
      </div>

      <div class="product-meta">
        <div class="product-meta__item">
          <span>Tasting Notes</span>
          <strong>{{ tasting_notes }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Roast Level</span>
          <strong>{{ roast_level }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Roast Date</span>
          <strong>{{ roast_date }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Process</span>
          <strong>{{ coffee_process }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Origin / Importer</span>
          <strong>{{ origin_importer }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Grind / Format</span>
          <strong>{{ grind_format }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Best For</span>
          <strong>{{ brew_methods }}</strong>
        </div>
        <div class="product-meta__item">
          <span>In The Bag</span>
          <strong>{{ bag_size }} coffee, {{ section.settings.market }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Origin Context</span>
          <strong>{{ origin_context }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Gift Note</span>
          <strong>{{ gift_message }}</strong>
        </div>
        <div class="product-meta__item">
          <span>Shipping / Returns</span>
          <strong>{{ shipping_returns }}</strong>
        </div>
      </div>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when '@app' %}
            {% render block %}
        {% endcase %}
      {% endfor %}

      {% if use_fallback_description %}
        <div class="rte">
          <p>{{ section.settings.description }}</p>
        </div>
      {% elsif product.description != blank %}
        <div class="rte">{{ product.description }}</div>
      {% else %}
        <p class="muted">{{ section.settings.description }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Yemeni Corner Signature Blend"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Whole Bean Coffee | 340 g | Medium Roast"
    },
    {
      "type": "text",
      "id": "tasting_notes",
      "label": "Tasting notes",
      "default": "Warm spice, cocoa, dried fruit"
    },
    {
      "type": "text",
      "id": "bag_size",
      "label": "Bag size",
      "default": "340 g whole bean"
    },
    {
      "type": "text",
      "id": "roast_level",
      "label": "Roast level",
      "default": "Medium, smooth, aromatic"
    },
    {
      "type": "text",
      "id": "roast_date",
      "label": "Roast date",
      "default": "Roast date confirmed per batch"
    },
    {
      "type": "text",
      "id": "coffee_process",
      "label": "Coffee process",
      "default": "Supplier-confirmed process pending"
    },
    {
      "type": "text",
      "id": "origin_importer",
      "label": "Origin / importer",
      "default": "Harraz area heritage; importer details pending supplier confirmation"
    },
    {
      "type": "text",
      "id": "grind_format",
      "label": "Grind / format",
      "default": "Whole bean coffee"
    },
    {
      "type": "text",
      "id": "best_for",
      "label": "Best for",
      "default": "Drip, French press, pour-over, espresso"
    },
    {
      "type": "text",
      "id": "market",
      "label": "Market",
      "default": "Canada shipping"
    },
    {
      "type": "text",
      "id": "origin_context",
      "label": "Origin context",
      "default": "Connected to the coffee heritage of the Harraz area of Yemen"
    },
    {
      "type": "text",
      "id": "gift_message",
      "label": "Gift message",
      "default": "A warm coffee gift for hosts, family, holidays, and coffee lovers"
    },
    {
      "type": "textarea",
      "id": "shipping_returns",
      "label": "Shipping / returns",
      "default": "Ships to Canadian customers. Shipping rates appear at checkout; returns follow the store policy for sealed coffee."
    },
    {
      "type": "textarea",
      "id": "trust_copy",
      "label": "Trust copy",
      "default": "We keep coffee details specific: confirmed bag format and brew guidance are shown now, and supplier-confirmed roast, process, origin, and importer details can be added here as soon as the batch record is available."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback description",
      "default": "A 340 g whole bean coffee inspired by Yemeni coffee heritage and the warmth of Yemeni Corner cafes. Expect a medium roast profile with warm spice, cocoa, and dried fruit notes. Brew it for slow mornings, shared tables, or a daily cup with more story behind it."
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout buttons",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
