<section class="section section--{{ section.settings.background }} heritage-section" data-section-id="{{ section.id }}">
  <div class="page-width heritage-section__inner">
    <div class="section-header heritage-section__header" data-reveal>
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <p class="lead">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="heritage-grid">
      {% for block in section.blocks %}
        <article class="heritage-card" data-reveal {{ block.shopify_attributes }}>
          {% if block.settings.kicker != blank %}
            <span class="heritage-card__kicker">{{ block.settings.kicker }}</span>
          {% endif %}
          <h3>{{ block.settings.title }}</h3>
          {% if block.settings.text != blank %}
            <div class="rte">{{ block.settings.text }}</div>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    {% if section.settings.note != blank %}
      <p class="heritage-section__note">{{ section.settings.note }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Heritage timeline",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "default": "white",
      "options": [
        { "value": "white", "label": "Warm white" },
        { "value": "cream", "label": "Cream" },
        { "value": "brown", "label": "Brown" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Yemeni Coffee Heritage"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A coffee story that began long before the bag"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Yemeni Corner uses public coffee history as education, then keeps product-specific claims limited to what is known about the Yemeni Corner Signature Blend."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Optional note",
      "default": "Product-specific sourcing details should be confirmed with supplier records before adding farm, process, altitude, or harvest claims."
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "15th century"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Coffee takes root in Yemen"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Coffee plants are historically tied to Ethiopia, then to cultivation and coffee drinking in southern Arabia, where Yemen helped shape coffee as a daily ritual.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Heritage timeline",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "kicker": "15th century",
            "title": "Coffee takes root in Yemen",
            "text": "<p>Coffee plants are historically tied to Ethiopia, then to cultivation and coffee drinking in southern Arabia, where Yemen helped shape coffee as a daily ritual.</p>"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "kicker": "Mocha",
            "title": "A port name becomes a coffee word",
            "text": "<p>The Yemeni port of Mocha became famous as a coffee-exporting center, and the name still echoes through coffee culture today.</p>"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "kicker": "Harraz",
            "title": "Mountain coffee with a reputation",
            "text": "<p>The Harraz area is recognized in the coffee world for Yemeni mountain coffees, terraced growing landscapes, and naturally warm, fruit-and-spice cup character.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
