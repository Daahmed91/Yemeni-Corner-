<article class="section" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header">
      <p class="eyebrow">{{ article.published_at | date: '%B %d, %Y' }}</p>
      <h1 class="heading-lg">{{ article.title }}</h1>
    </div>

    {% if article.image %}
      <div class="media-panel">
        {{
          article.image
          | image_url: width: 1600
          | image_tag:
            widths: '720, 960, 1200, 1600',
            sizes: '92vw',
            loading: 'eager',
            alt: article.image.alt | default: article.title
        }}
      </div>
    {% endif %}

    <div class="rte">
      {{ article.content }}
    </div>

    <div class="button-row">
      <a class="button button--secondary" href="{{ blog.url }}">{{ 'blogs.article.back_to_blog' | t }}</a>
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Main article",
  "settings": []
}
{% endschema %}

