<section class="section cafe-favorites" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header" data-reveal>
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <p class="lead">{{ section.settings.text }}</p>
      {% endif %}
      <div class="button-row">
        {% if section.settings.primary_label != blank %}
          <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>

    <div class="cafe-favorites__grid">
      {% for block in section.blocks %}
        {%- liquid
          assign fallback_asset = 'yemeni-corner-ritual.webp'
          assign favorite_handle = block.settings.title | handle
          case favorite_handle
            when 'adeni-tea'
              assign fallback_asset = 'yc-cafe-adeni-tea.webp'
            when 'mufawar-coffee'
              assign fallback_asset = 'yc-cafe-mufawar.webp'
            when 'yemeni-latte'
              assign fallback_asset = 'yc-cafe-yemeni-latte.webp'
            when 'pistachio-latte'
              assign fallback_asset = 'yc-cafe-pistachio-latte.webp'
            when 'tawahi-lemonade'
              assign fallback_asset = 'yc-cafe-tawahi-lemonade.webp'
            when 'saffron-milk-cake'
              assign fallback_asset = 'yc-cafe-saffron-milk-cake.webp'
          endcase
        -%}
        <article class="cafe-favorite" data-reveal {{ block.shopify_attributes }}>
          <div class="cafe-favorite__image">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  widths: '320, 480, 640, 900',
                  sizes: '(min-width: 960px) 30vw, (min-width: 720px) 44vw, 92vw',
                  loading: 'lazy',
                  alt: block.settings.title
              }}
            {% else %}
              <img src="{{ fallback_asset | asset_url }}" alt="{{ block.settings.title | escape }}" width="900" height="680" loading="lazy">
            {% endif %}
            {% if block.settings.badge != blank %}
              <span class="cafe-favorite__badge">{{ block.settings.badge }}</span>
            {% endif %}
          </div>
          <div class="cafe-favorite__content">
            <span>{{ block.settings.category }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cafe favorites",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Cafe Favorites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The drinks that make the cafe memorable"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Traditional drinks, signature lattes, cold favorites, and desserts give Yemeni Corner its full flavor. The Signature Blend brings part of that warmth home."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Explore Cafe Menu"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link",
      "default": "/pages/menu"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Shop Signature Blend"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link",
      "default": "/products/yemeni-corner-harraz-signature-roast"
    }
  ],
  "blocks": [
    {
      "type": "favorite",
      "name": "Favorite",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Traditional"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Adeni Tea"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A warm cafe favorite with tea, milk, and layered spice."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Optional badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cafe favorites",
      "blocks": [
        { "type": "favorite", "settings": { "category": "Traditional", "title": "Adeni Tea", "description": "Black tea, milk, and warming spice with the comfort of a shared table.", "badge": "Warm spice" } },
        { "type": "favorite", "settings": { "category": "Traditional", "title": "Mufawar Coffee", "description": "A Yemeni coffee house staple with aromatic spice and a generous finish.", "badge": "Heritage cup" } },
        { "type": "favorite", "settings": { "category": "Signature", "title": "Yemeni Latte", "description": "A familiar latte turned toward Yemeni-inspired spice, sweetness, and warmth.", "badge": "House favorite" } },
        { "type": "favorite", "settings": { "category": "Signature", "title": "Pistachio Latte", "description": "Nutty, smooth, and rich enough to feel like dessert in a cup.", "badge": "Creamy" } },
        { "type": "favorite", "settings": { "category": "Cold", "title": "Tawahi Lemonade", "description": "Bright, refreshing, and made for sharing on warmer cafe days.", "badge": "Fresh" } },
        { "type": "favorite", "settings": { "category": "Dessert", "title": "Saffron Milk Cake", "description": "Soft, fragrant, and made to sit beside a slow coffee or tea.", "badge": "Sweet finish" } }
      ]
    }
  ]
}
{% endschema %}
