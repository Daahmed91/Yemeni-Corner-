<section class="section section--cream" data-section-id="{{ section.id }}" data-brew-guide>
  <div class="page-width">
    <div class="section-header" data-reveal>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      <p class="lead">{{ section.settings.text }}</p>
    </div>

    <div class="brew-progress" aria-hidden="true">
      <span data-brew-progress></span>
    </div>

    <div class="brew-grid">
      {% for block in section.blocks %}
        <article
          class="brew-card {% if forloop.first %}is-active{% endif %}"
          data-brew-step
          data-reveal
          tabindex="0"
          role="button"
          aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
          {{ block.shopify_attributes }}
        >
          <span>{{ block.settings.step }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brew guide",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "A Richer Way to Brew"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Brew with intention, not complication"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Designed for familiar home methods, the Yemeni Corner Signature Blend brings warmth and depth to drip, French press, pour-over, and espresso."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Brew step",
      "settings": [
        {
          "type": "text",
          "id": "step",
          "label": "Step label",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Grind fresh"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Use a medium grind for drip and pour-over, coarse for French press, and fine for espresso."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brew guide",
      "blocks": [
        { "type": "step", "settings": { "step": "01", "title": "Grind for the method", "text": "Use a medium grind for drip and pour-over, coarse for French press, and fine for espresso." } },
        { "type": "step", "settings": { "step": "02", "title": "Start with a simple ratio", "text": "Try 1:15 to 1:16 coffee to water for drip or pour-over, then adjust stronger or softer to taste." } },
        { "type": "step", "settings": { "step": "03", "title": "Let the notes open", "text": "Clean water and a steady brew help the warm spice, cocoa, and dried fruit character come forward." } },
        { "type": "step", "settings": { "step": "04", "title": "Store it well", "text": "Keep the bag sealed in a cool, dry place and grind only what you need." } }
      ]
    }
  ]
}
{% endschema %}
