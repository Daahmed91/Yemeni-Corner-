{%- liquid
  assign footer_menu = linklists[section.settings.menu]
  assign story_page = pages['story']
  assign menu_page = pages['menu']
  assign locations_page = pages['locations']
  assign south_windsor_page = pages['south-windsor']
  assign lasalle_page = pages['lasalle']
  assign contact_page = pages['contact']
  assign brand_name = settings.seo_site_name | default: shop.name
  assign story_url = routes.root_url | append: '#story'
  if story_page != blank
    assign story_url = story_page.url
  endif
  assign menu_url = menu_page.url | default: '/pages/menu'
  assign locations_url = routes.root_url | append: '#locations'
  if locations_page != blank
    assign locations_url = locations_page.url
  endif
  assign south_windsor_url = locations_url
  if south_windsor_page != blank
    assign south_windsor_url = south_windsor_page.url
  endif
  assign lasalle_url = locations_url
  if lasalle_page != blank
    assign lasalle_url = lasalle_page.url
  endif
  assign careers_url = '/careers'
  assign contact_url = contact_page.url | default: '/pages/contact'
  assign coffee_collection = collections['coffee']
  assign shop_url = section.settings.shop_link
  if shop_url == blank and coffee_collection != blank
    assign shop_url = coffee_collection.url
  endif
  if shop_url == blank
    assign shop_url = routes.all_products_collection_url
  endif
-%}

<footer class="site-footer" data-section-id="{{ section.id }}">
  <div class="page-width site-footer__inner">
    <div class="site-footer__brand">
      <a class="site-footer__logo-link" href="{{ routes.root_url }}" aria-label="{{ brand_name }}">
        {% if settings.logo_dark != blank %}
          {{
            settings.logo_dark
            | image_url: width: 720
            | image_tag:
              widths: '280, 420, 560, 720',
              sizes: '(min-width: 960px) 300px, 220px',
              loading: 'lazy',
              class: 'site-footer__logo',
              alt: brand_name
          }}
        {% else %}
          <img
            class="site-footer__logo site-footer__logo--official"
            src="{{ 'yemeni-corner-official-logo.png' | asset_url }}"
            width="1264"
            height="1264"
            loading="lazy"
            alt="{{ brand_name | escape }}"
          >
        {% endif %}
      </a>
      <p>{{ settings.brand_statement | default: "Premium Yemeni coffee rooted in heritage, crafted for today's coffee drinker." }}</p>
      <p class="eyebrow">{{ settings.brand_tagline | default: 'Premium Yemeni Coffee' }}</p>
    </div>

    <div>
      <h3 class="site-footer__title">Explore</h3>
      <ul class="footer-nav">
        {% if section.settings.use_curated_navigation %}
          <li><a href="{{ shop_url }}">Shop Coffee</a></li>
          <li><a href="{{ story_url }}">Our Story</a></li>
          <li><a href="{{ menu_url }}">Cafe Menu</a></li>
          <li><a href="{{ locations_url }}">Locations</a></li>
          <li><a href="{{ careers_url }}">Careers</a></li>
          <li><a href="{{ contact_url }}">Contact</a></li>
        {% elsif footer_menu.links.size > 0 %}
          {% for link in footer_menu.links %}
            {%- liquid
              assign link_url = link.url
              assign link_title_handle = link.title | handle
              if link_title_handle == 'careers'
                assign link_url = careers_url
              endif
            -%}
            <li><a href="{{ link_url }}">{{ link.title }}</a></li>
          {% endfor %}
        {% else %}
          <li><a href="{{ shop_url }}">Shop Coffee</a></li>
          <li><a href="{{ story_url }}">Our Story</a></li>
          <li><a href="{{ menu_url }}">Cafe Menu</a></li>
          <li><a href="{{ locations_url }}">Locations</a></li>
          <li><a href="{{ careers_url }}">Careers</a></li>
          <li><a href="{{ contact_url }}">Contact</a></li>
        {% endif %}
      </ul>
    </div>

    <div>
      <h3 class="site-footer__title">Visit Us</h3>
      <p>
        <a href="{{ south_windsor_url }}">South Windsor</a><br>
        350 Cabana Rd E<br>
        Windsor, ON<br>
        <a
          href="tel:5199150595"
          data-yc-event="phone_click"
          data-yc-event-location="South Windsor"
          data-yc-event-source="footer"
        >
          519-915-0595
        </a>
      </p>
      <p>
        <a href="{{ lasalle_url }}">LaSalle</a><br>
        5881 Malden Rd<br>
        LaSalle, ON<br>
        <a
          href="tel:5199151119"
          data-yc-event="phone_click"
          data-yc-event-location="LaSalle"
          data-yc-event-source="footer"
        >
          519-915-1119
        </a>
      </p>
      <p>
        <a
          href="https://share.google/wcsuVJwqdAe4cnCKP"
          data-yc-event="directions_click"
          data-yc-event-location="Mechanicsburg, PA"
          data-yc-event-source="footer"
        >
          Mechanicsburg, PA
        </a><br>
        4957 Carlisle Pike<br>
        Mechanicsburg, PA 17050
      </p>
    </div>

    <div>
      <h3 class="site-footer__title">Connect</h3>
      <ul class="social-list">
        {% if settings.social_instagram_link != blank %}
          <li><a href="{{ settings.social_instagram_link }}">Instagram</a></li>
        {% else %}
          <li><a href="https://www.instagram.com/yemenicorner/">Instagram</a></li>
        {% endif %}
        {% if settings.social_facebook_link != blank %}
          <li><a href="{{ settings.social_facebook_link }}">Facebook</a></li>
        {% endif %}
        <li><a href="{{ careers_url }}">Careers</a></li>
        <li><a href="{{ contact_url }}">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="page-width site-footer__bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ brand_name | default: 'Yemeni Corner' }}</span>
    <span>Cafe hospitality in Ontario and Pennsylvania, with Yemeni coffee for home brewing.</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "checkbox",
      "id": "use_curated_navigation",
      "label": "Use curated coffee navigation",
      "default": true
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Shop Coffee navigation link"
    }
  ]
}
{% endschema %}
