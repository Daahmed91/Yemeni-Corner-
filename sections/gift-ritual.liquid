{%- liquid
  assign product_item = all_products[section.settings.product]
  assign primary_url = section.settings.primary_link
  if primary_url == blank and product_item != blank
    assign primary_url = product_item.url
  endif
  if primary_url == blank
    assign primary_url = routes.all_products_collection_url
  endif
-%}

<section class="section section--brown gift-ritual" data-section-id="{{ section.id }}">
  <div class="page-width gift-ritual__inner">
    <div class="gift-ritual__copy" data-reveal>
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      <p class="lead">{{ section.settings.text }}</p>

      <div class="gift-ritual__points" aria-label="Gift highlights">
        <span>For hosts</span>
        <span>For family</span>
        <span>For coffee lovers</span>
      </div>

      <div class="button-row">
        <a class="button button--gold" href="{{ primary_url }}">{{ section.settings.primary_label }}</a>
        {% if section.settings.secondary_label != blank %}
          <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>

    <div class="gift-ritual__media" data-reveal data-parallax data-parallax-speed="0.025">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            widths: '420, 640, 900, 1200',
            sizes: '(min-width: 960px) 42vw, 92vw',
            loading: 'lazy',
            alt: section.settings.image.alt | default: section.settings.heading
        }}
      {% else %}
        <img src="{{ 'yc-signature-blend-gift.webp' | asset_url }}" alt="Yemeni Corner Signature Blend gift ritual" width="1200" height="900" loading="lazy">
      {% endif %}
      <div class="gift-ritual__badge">
        <span>Gift-ready coffee</span>
        <strong>One to brew, one to share.</strong>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gift the ritual",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Gift the Ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gift the Yemeni Corner ritual"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The Yemeni Corner Signature Blend is a warm, thoughtful coffee gift for hosts, family, holidays, and anyone who loves a cup with a story behind it."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Gift the Signature Blend"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Visit Our Cafes"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link",
      "default": "/#locations"
    }
  ],
  "presets": [
    {
      "name": "Gift the ritual"
    }
  ]
}
{% endschema %}
